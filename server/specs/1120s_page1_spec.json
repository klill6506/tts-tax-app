  "rules": [
    {
      "rule_id": "R001",
      "title": "Net receipts",
      "description": "Line 1c = Line 1a - Line 1b",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "gross_receipts - returns_allowances",
      "inputs": [
        "gross_receipts",
        "returns_allowances"
      ],
      "outputs": [
        "net_receipts"
      ],
      "precedence": 1,
      "exceptions": "",
      "notes": "",
      "sort_order": 1,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Page 1 income computation",
          "source_code": "IRS_2025_1120S_INSTR_FULL",
          "title": "Instructions for Form 1120-S (2025) \u2014 Full Document (fetched 2026-03-18)",
          "citation": "Instructions for Form 1120-S (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R002",
      "title": "Gross profit",
      "description": "Line 3 = Line 1c - Line 2 (cost of goods sold from Form 1125-A)",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "net_receipts - cost_of_goods_sold",
      "inputs": [
        "net_receipts",
        "cost_of_goods_sold"
      ],
      "outputs": [
        "gross_profit"
      ],
      "precedence": 2,
      "exceptions": "",
      "notes": "",
      "sort_order": 2,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Gross profit = net receipts - COGS",
          "source_code": "IRS_2025_1120S_INSTR_FULL",
          "title": "Instructions for Form 1120-S (2025) \u2014 Full Document (fetched 2026-03-18)",
          "citation": "Instructions for Form 1120-S (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R003",
      "title": "Page 1 Line 4 = Form 4797 Part II Line 17",
      "description": "Net gain (loss) from Form 4797. This is the ORDINARY gain/loss from Part II Line 17, which includes short-term dispositions and recapture from Part III Line 31. NOT the Section 1231 gain from Part I \u2014 that goes to Schedule K Line 9.",
      "rule_type": "routing",
      "conditions": {},
      "formula": "Form_4797_Part_II_Line_17",
      "inputs": [
        "4797_part2_line17"
      ],
      "outputs": [
        "net_gain_4797"
      ],
      "precedence": 3,
      "exceptions": "",
      "notes": "VERIFIED from fresh IRS 1120-S instructions fetch 2026-03-18. This was a persistent bug source in tts-tax-app.",
      "sort_order": 3,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Line 4 = Form 4797 Part II Line 17 (verified from fetched instructions)",
          "source_code": "IRS_2025_1120S_INSTR_FULL",
          "title": "Instructions for Form 1120-S (2025) \u2014 Full Document (fetched 2026-03-18)",
          "citation": "Instructions for Form 1120-S (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        },
        {
          "support_level": "secondary",
          "relevance_note": "Form 4797 Part II Line 17 = ordinary gains/losses",
          "source_code": "IRS_2025_4797_INSTR",
          "title": "Instructions for Form 4797 (2025) \u2014 Sales of Business Property",
          "citation": "Instructions for Form 4797 (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R004",
      "title": "Total income",
      "description": "Line 6 = Line 3 + Line 4 + Line 5",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "gross_profit + net_gain_4797 + other_income",
      "inputs": [
        "gross_profit",
        "net_gain_4797",
        "other_income"
      ],
      "outputs": [
        "total_income"
      ],
      "precedence": 4,
      "exceptions": "",
      "notes": "",
      "sort_order": 4,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Total income = lines 3+4+5",
          "source_code": "IRS_2025_1120S_INSTR_FULL",
          "title": "Instructions for Form 1120-S (2025) \u2014 Full Document (fetched 2026-03-18)",
          "citation": "Instructions for Form 1120-S (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R005",
      "title": "Total deductions",
      "description": "Line 20 = sum of Lines 7 through 19. Section 179 is NOT included here \u2014 it is separately stated on Schedule K Line 11.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "officer_compensation + salaries_wages + repairs_maintenance + bad_debts + rents + taxes_licenses + interest + depreciation + depletion + advertising + pension_plans + employee_benefits + other_deductions",
      "inputs": [
        "officer_compensation",
        "salaries_wages",
        "repairs_maintenance",
        "bad_debts",
        "rents",
        "taxes_licenses",
        "interest",
        "depreciation",
        "depletion",
        "advertising",
        "pension_plans",
        "employee_benefits",
        "other_deductions"
      ],
      "outputs": [
        "total_deductions"
      ],
      "precedence": 5,
      "exceptions": "",
      "notes": "",
      "sort_order": 5,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Total deductions = sum lines 7-19",
          "source_code": "IRS_2025_1120S_INSTR_FULL",
          "title": "Instructions for Form 1120-S (2025) \u2014 Full Document (fetched 2026-03-18)",
          "citation": "Instructions for Form 1120-S (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R006",
      "title": "Ordinary business income (loss)",
      "description": "Line 21 = Line 6 - Line 20. This is the key output of Page 1. Flows to Schedule K Line 1 for shareholder allocation.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "total_income - total_deductions",
      "inputs": [
        "total_income",
        "total_deductions"
      ],
      "outputs": [
        "ordinary_business_income"
      ],
      "precedence": 6,
      "exceptions": "",
      "notes": "",
      "sort_order": 6,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Line 21 = Line 6 - Line 20, flows to K Line 1",
          "source_code": "IRS_2025_1120S_INSTR_FULL",
          "title": "Instructions for Form 1120-S (2025) \u2014 Full Document (fetched 2026-03-18)",
          "citation": "Instructions for Form 1120-S (2025)",
          "source_type": "official_instruction",
