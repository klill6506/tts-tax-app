  "rules": [
    {
      "rule_id": "R001",
      "title": "Short-term vs long-term classification",
      "description": "Property held more than 1 year is long-term. 1 year or less is short-term.",
      "rule_type": "classification",
      "conditions": {},
      "formula": "if holding_period_months > 12 then \"long_term\" else \"short_term\"",
      "inputs": [
        "date_acquired",
        "date_sold"
      ],
      "outputs": [
        "holding_period_class"
      ],
      "precedence": 1,
      "exceptions": "",
      "notes": "",
      "sort_order": 1,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "\u00a71222 defines short-term vs long-term",
          "source_code": "IRC_1222",
          "title": "IRC \u00a71222 \u2014 Other Terms Relating to Capital Gains and Losses",
          "citation": "26 U.S.C. \u00a71222",
          "source_type": "code_section",
          "source_rank": "controlling"
        }
      ]
    },
    {
      "rule_id": "R002",
      "title": "Aggregate short-term",
      "description": "Sum all short-term capital gains and losses from Form 8949 categories.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "sum of all short-term gains/losses from Form 8949 Part I",
      "inputs": [
        "short_term_transactions"
      ],
