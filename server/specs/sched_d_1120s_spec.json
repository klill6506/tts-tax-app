    {
      "rule_id": "R005",
      "title": "Built-in gains tax (\u00a71374)",
      "description": "C-Corp converting to S-Corp may owe BIG tax on built-in gains recognized within 5-year recognition period. Tax is at 21% corporate rate. Limited to net unrealized built-in gain at conversion.",
      "rule_type": "calculation",
      "conditions": {
        "when": "built_in_gains_tax_applicable == true AND within recognition period (5 years)"
      },
      "formula": "net_recognized_built_in_gain * 0.21",
      "inputs": [
        "built_in_gains_tax_applicable",
        "net_recognized_built_in_gain",
        "net_unrealized_built_in_gain"
      ],
      "outputs": [
        "big_tax"
      ],
      "precedence": 15,
      "exceptions": "",
      "notes": "NEEDS REVIEW \u2014 recognition period rules, net unrealized built-in gain limitation, and carryover of unused BIG.",
      "sort_order": 5,
      "authorities": [
        {
          "support_level": "primary",
