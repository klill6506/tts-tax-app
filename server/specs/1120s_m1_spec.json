  "rules": [
    {
      "rule_id": "R001",
      "title": "Line 4 subtotal",
      "description": "Line 4 = Line 1 + Line 2 + Line 3a + Line 3b. This is book income plus add-backs.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "book_net_income + income_on_k_not_books + guaranteed_payments + expenses_not_on_k",
      "inputs": [
        "book_net_income",
        "income_on_k_not_books",
        "guaranteed_payments",
        "expenses_not_on_k"
      ],
      "outputs": [
        "line_4_subtotal"
      ],
      "precedence": 1,
      "exceptions": "",
      "notes": "",
      "sort_order": 1,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "M-1 Lines 1-3b: book income + add-backs",
          "source_code": "IRS_2025_1120S_INSTR_FULL",
          "title": "Instructions for Form 1120-S (2025) \u2014 Full Document (fetched 2026-03-18)",
          "citation": "Instructions for Form 1120-S (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R002",
      "title": "Line 6 subtotal",
      "description": "Line 6 = Line 5a + Line 5b. These are subtractions (book income not taxable + tax deductions not on books).",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "income_on_books_not_k + deductions_on_k_not_books",
      "inputs": [
        "income_on_books_not_k",
        "deductions_on_k_not_books"
      ],
      "outputs": [
        "line_6_subtotal"
      ],
      "precedence": 2,
      "exceptions": "",
      "notes": "",
      "sort_order": 2,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "M-1 Lines 5a-5b: subtractions",
          "source_code": "IRS_2025_1120S_INSTR_FULL",
          "title": "Instructions for Form 1120-S (2025) \u2014 Full Document (fetched 2026-03-18)",
          "citation": "Instructions for Form 1120-S (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R003",
      "title": "Line 7 = Income per return",
      "description": "Line 7 = Line 4 - Line 6. This is the taxable income per the return.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "line_4_subtotal - line_6_subtotal",
      "inputs": [
        "line_4_subtotal",
        "line_6_subtotal"
      ],
      "outputs": [
        "income_per_return"
      ],
      "precedence": 3,
      "exceptions": "",
      "notes": "",
      "sort_order": 3,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "M-1 Line 7 = Line 4 - Line 6",
          "source_code": "IRS_2025_1120S_INSTR_FULL",
          "title": "Instructions for Form 1120-S (2025) \u2014 Full Document (fetched 2026-03-18)",
          "citation": "Instructions for Form 1120-S (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R004",
      "title": "M-1 balance check",
      "description": "Line 7 (and Line 8) must equal Page 1 Line 21 (ordinary business income). If they differ, the M-1 reconciliation is incorrect.",
      "rule_type": "validation",
      "conditions": {},
      "formula": "income_per_return == page1_line_21",
      "inputs": [
        "income_per_return"
      ],
      "outputs": [],
      "precedence": 10,
      "exceptions": "",
      "notes": "",
      "sort_order": 4,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Line 8 must equal Page 1 Line 21",
          "source_code": "IRS_2025_1120S_INSTR_FULL",
          "title": "Instructions for Form 1120-S (2025) \u2014 Full Document (fetched 2026-03-18)",
          "citation": "Instructions for Form 1120-S (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R005",
      "title": "Line 3b must be positive (add-back)",
      "description": "Line 3b represents expenses on books that are NOT deductible on the return (e.g., 50% of meals, fines, penalties). This is an ADD-BACK to book income, so it must be a positive number. A negative value would incorrectly subtract from taxable income.",
      "rule_type": "validation",
      "conditions": {},
      "formula": "expenses_not_on_k >= 0",
      "inputs": [
        "expenses_not_on_k"
      ],
      "outputs": [],
      "precedence": 0,
      "exceptions": "",
      "notes": "CRITICAL: M-1 Line 3b sign error was a persistent bug in tts-tax-app. Line 3b is ALWAYS an addition.",
      "sort_order": 5,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Line 3b is expenses on books not deducted = ADD-BACK",
          "source_code": "IRS_2025_1120S_INSTR_FULL",
          "title": "Instructions for Form 1120-S (2025) \u2014 Full Document (fetched 2026-03-18)",
          "citation": "Instructions for Form 1120-S (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R006",
      "title": "Guaranteed payments must be zero for S-Corps",
      "description": "Line 3a (guaranteed payments under section 707(c)) applies only to partnerships. For S-Corps, this line must be zero.",
      "rule_type": "validation",
      "conditions": {},
      "formula": "guaranteed_payments == 0 when entity_type == '1120S'",
      "inputs": [
        "guaranteed_payments"
      ],
      "outputs": [],
      "precedence": 0,
      "exceptions": "",
      "notes": "",
      "sort_order": 6,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Line 3a guaranteed payments \u2014 partnerships only",
          "source_code": "IRS_2025_1120S_INSTR_FULL",
          "title": "Instructions for Form 1120-S (2025) \u2014 Full Document (fetched 2026-03-18)",
          "citation": "Instructions for Form 1120-S (2025)",
