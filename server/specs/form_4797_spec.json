  "rules": [
    {
      "rule_id": "R001",
      "title": "Determine holding period classification",
      "description": "Classify as long-term (>12 months) or short-term (<=12 months). This determines routing between Part I/III vs Part II.",
      "rule_type": "classification",
      "conditions": {},
      "formula": "if holding_period_months > 12 then \"long_term\" else \"short_term\"",
      "inputs": [
        "holding_period_months"
      ],
      "outputs": [
        "holding_period_class"
      ],
      "precedence": 1,
      "exceptions": "",
      "notes": "",
      "sort_order": 0,
      "authorities": []
    },
    {
      "rule_id": "R002",
      "title": "Route to correct Part based on property type and holding period",
      "description": "Core routing logic for Form 4797:\n- Short-term \u2192 Part II (ordinary)\n- Long-term + \u00a71245/\u00a71250 + gain \u2192 Part III first (recapture), excess to Part I\n- Long-term + gain + no recapture items \u2192 Part I (\u00a71231)\n- Long-term + loss \u2192 Part I (\u00a71231 loss)",
      "rule_type": "routing",
      "conditions": {},
      "formula": "if holding_period_class == \"short_term\" then \"Part II\" else \"Part I\"",
      "inputs": [
        "holding_period_class",
        "property_type",
        "gain_or_loss"
      ],
      "outputs": [
        "form_part_destination"
      ],
      "precedence": 5,
      "exceptions": "",
      "notes": "NEEDS REVIEW \u2014 simplified routing. Full routing requires checking if property has recapture potential (\u00a71245/\u00a71250 with gain) which triggers Part III first. The formula here captures the basic long/short split but not the Part III \u2192 Part I overflow.",
      "sort_order": 0,
      "authorities": []
    },
    {
      "rule_id": "R003",
      "title": "Calculate gain or loss",
      "description": "Basic gain/loss calculation: sale price minus adjusted basis.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "sale_price - adjusted_basis",
      "inputs": [
        "sale_price",
        "adjusted_basis"
      ],
      "outputs": [
        "gain_or_loss"
      ],
      "precedence": 2,
      "exceptions": "",
      "notes": "",
      "sort_order": 0,
      "authorities": []
    },
    {
      "rule_id": "R004",
      "title": "Calculate adjusted basis",
      "description": "Adjusted basis = original cost minus all depreciation allowed or allowable.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "cost_or_basis - depreciation_allowed",
      "inputs": [
        "cost_or_basis",
        "depreciation_allowed"
      ],
      "outputs": [
        "adjusted_basis"
      ],
      "precedence": 0,
      "exceptions": "",
      "notes": "This runs first (precedence 0) since other rules depend on adjusted_basis.",
      "sort_order": 0,
      "authorities": []
    },
    {
      "rule_id": "R005",
      "title": "Section 1245 recapture \u2014 ordinary income portion",
      "description": "For \u00a71245 property, ALL gain up to total depreciation allowed is recaptured as ordinary income. This is the full recapture rule \u2014 \u00a71245 does not distinguish between straight-line and accelerated.",
      "rule_type": "calculation",
      "conditions": {
        "when": "property_type == \"1245\" and gain_or_loss > 0"
      },
      "formula": "min(gain_or_loss, depreciation_allowed)",
      "inputs": [
        "gain_or_loss",
        "depreciation_allowed",
        "property_type"
      ],
      "outputs": [
        "ordinary_income_1245"
      ],
      "precedence": 10,
      "exceptions": "",
      "notes": "",
      "sort_order": 0,
      "authorities": []
    },
    {
      "rule_id": "R006",
      "title": "Section 1245 excess gain \u2192 \u00a71231 gain",
      "description": "If gain exceeds total depreciation on \u00a71245 property, the excess is \u00a71231 gain that flows to Part I.",
      "rule_type": "calculation",
      "conditions": {
        "when": "property_type == \"1245\" and gain_or_loss > 0"
      },
      "formula": "max(0, gain_or_loss - depreciation_allowed)",
      "inputs": [
        "gain_or_loss",
        "depreciation_allowed",
        "property_type"
      ],
      "outputs": [
        "section_1231_gain_excess"
      ],
      "precedence": 11,
      "exceptions": "",
      "notes": "",
      "sort_order": 0,
      "authorities": []
    },
    {
      "rule_id": "R007",
      "title": "Section 1250 recapture \u2014 ordinary income (additional depreciation)",
      "description": "For \u00a71250 property, only ADDITIONAL depreciation (excess over straight-line) is recaptured as ordinary income. For post-1986 MACRS real property using SL, additional depreciation is zero, so \u00a71250 ordinary recapture is usually zero.",
      "rule_type": "calculation",
      "conditions": {
        "when": "property_type == \"1250\" and gain_or_loss > 0"
      },
      "formula": "0",
      "inputs": [
        "gain_or_loss",
        "depreciation_allowed",
        "property_type"
      ],
      "outputs": [
        "ordinary_income_1250"
      ],
      "precedence": 10,
      "exceptions": "",
      "notes": "NEEDS REVIEW \u2014 Formula hardcoded to 0 because post-1986 MACRS real property uses straight-line, so additional depreciation is zero. For pre-1987 property or property using accelerated methods, this would need the actual additional depreciation calculation.",
      "sort_order": 0,
      "authorities": []
    },
    {
      "rule_id": "R008",
      "title": "Unrecaptured \u00a71250 gain (25% rate bucket)",
      "description": "For \u00a71250 property, gain attributable to depreciation that is NOT ordinary under \u00a71250 is 'unrecaptured \u00a71250 gain' taxed at a maximum 25% rate. This equals the lesser of the gain or total depreciation, minus any \u00a71250 ordinary recapture.",
      "rule_type": "calculation",
      "conditions": {
        "when": "property_type == \"1250\" and gain_or_loss > 0"
      },
      "formula": "min(gain_or_loss, depreciation_allowed) - ordinary_income_1250",
      "inputs": [
        "gain_or_loss",
        "depreciation_allowed",
        "ordinary_income_1250",
        "property_type"
      ],
      "outputs": [
        "unrecaptured_1250_gain"
      ],
      "precedence": 12,
      "exceptions": "",
      "notes": "",
      "sort_order": 0,
      "authorities": []
    },
    {
      "rule_id": "R010",
      "title": "Net \u00a71231 gain/loss netting",
      "description": "All \u00a71231 gains and losses are netted. If net gain \u2192 long-term capital gain. If net loss \u2192 ordinary loss. Subject to 5-year lookback rule under \u00a71231(c).",
      "rule_type": "calculation",
      "conditions": {
        "when": "total_1231_gains >= 0"
      },
      "formula": "total_1231_gains - total_1231_losses",
      "inputs": [
        "total_1231_gains",
        "total_1231_losses"
      ],
      "outputs": [
        "net_1231_gain_loss"
      ],
      "precedence": 50,
      "exceptions": "",
      "notes": "Only runs when aggregation inputs are provided (not per-property).",
      "sort_order": 0,
      "authorities": []
    }
  ],
