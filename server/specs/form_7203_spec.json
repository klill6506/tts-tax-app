      "diagnostic_id": "D001",
      "title": "Stock basis negative",
      "severity": "error",
      "condition": "stock_basis_eoy < 0",
      "message": "Stock basis computed as negative \u2014 this is a calculation error. Stock basis cannot go below zero.",
      "notes": ""
    },
    {
      "diagnostic_id": "D002",
      "title": "Losses suspended",
      "severity": "info",
      "condition": "suspended_losses > 0",
      "message": "Losses exceed stock + debt basis and are suspended. Carried forward indefinitely with character retained.",
