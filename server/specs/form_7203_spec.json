  "tests": [
    {
      "scenario_name": "Sufficient basis \u2014 all items flow",
      "scenario_type": "normal",
      "inputs": {
        "income_items": 50000,
        "distributions": 30000,
        "stock_basis_boy": 100000,
        "additional_stock": 0,
        "losses_deductions": 0,
        "nondeductible_expenses": 2000
      },
      "expected_outputs": {
        "stock_basis_eoy": 118000,
        "suspended_losses": 0,
        "stock_basis_before_decreases": 150000
      },
      "notes": "",
      "sort_order": 1
    },
    {
      "scenario_name": "Distribution exceeds basis \u2014 capital gain",
      "scenario_type": "edge",
      "inputs": {
        "income_items": 10000,
        "distributions": 50000,
        "stock_basis_boy": 20000,
        "additional_stock": 0,
        "losses_deductions": 0,
        "nondeductible_expenses": 0
      },
      "expected_outputs": {
        "stock_basis_eoy": 0,
        "distribution_capital_gain": 20000,
        "stock_basis_before_decreases": 30000
      },
      "notes": "",
      "sort_order": 2
    },
    {
      "scenario_name": "Losses suspended \u2014 insufficient basis",
      "scenario_type": "edge",
      "inputs": {
        "income_items": 5000,
        "distributions": 0,
        "debt_basis_boy": 5000,
        "stock_basis_boy": 15000,
        "additional_stock": 0,
        "losses_deductions": 30000,
        "nondeductible_expenses": 0
      },
      "expected_outputs": {
        "debt_basis_eoy": 0,
        "stock_basis_eoy": 0,
        "suspended_losses": 5000
      },
      "notes": "20K stock basis absorbs 20K of losses. 5K debt basis absorbs 5K more. 5K suspended.",
      "sort_order": 3
    },
    {
      "scenario_name": "Debt basis restoration",
      "scenario_type": "edge",
      "inputs": {
        "income_items": 25000,
        "distributions": 0,
        "debt_basis_boy": 10000,
        "stock_basis_boy": 0,
        "losses_deductions": 0,
        "prior_debt_reduction": 8000,
        "nondeductible_expenses": 0
      },
      "expected_outputs": {
        "stock_basis_eoy": 25000,
        "debt_basis_restoration": 8000
      },
      "notes": "Net income increase restores previously reduced debt basis.",
      "sort_order": 4
    }
