  "rules": [
    {
      "rule_id": "R001",
      "title": "Stock basis before decreases (Line 4)",
      "description": "",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "stock_basis_boy + additional_stock + income_items",
      "inputs": [
        "stock_basis_boy",
        "additional_stock",
        "income_items"
      ],
      "outputs": [
        "stock_basis_before_decreases"
      ],
      "precedence": 1,
      "exceptions": "",
      "notes": "",
      "sort_order": 1,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Stock basis computation",
          "source_code": "IRS_2025_7203_INSTR_FULL",
          "title": "Instructions for Form 7203 (2025) \u2014 S Corporation Shareholder Stock and Debt Basis Limitation (fetched 2026-03-18)",
          "citation": "Instructions for Form 7203 (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        },
        {
          "support_level": "secondary",
          "relevance_note": "Section 1367 \u2014 adjustments to basis",
          "source_code": "IRC_1367",
          "title": "IRC \u00a71367 \u2014 Adjustments to Basis of Stock of Shareholders",
          "citation": "26 U.S.C. \u00a71367",
          "source_type": "code_section",
          "source_rank": "controlling"
        }
      ]
    },
    {
      "rule_id": "R002",
      "title": "Distributions reduce basis first (Line 6)",
      "description": "Distributions reduce stock basis but not below zero. Excess distributions are return of basis/capital gain per section 1368.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "stock_after_dist = max(0, stock_basis_before_decreases - distributions)",
      "inputs": [
        "stock_basis_before_decreases",
        "distributions"
      ],
      "outputs": [
        "stock_after_distributions"
      ],
      "precedence": 2,
      "exceptions": "",
      "notes": "",
      "sort_order": 2,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Distributions reduce first, floor at zero",
          "source_code": "IRS_2025_7203_INSTR_FULL",
          "title": "Instructions for Form 7203 (2025) \u2014 S Corporation Shareholder Stock and Debt Basis Limitation (fetched 2026-03-18)",
          "citation": "Instructions for Form 7203 (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        },
        {
          "support_level": "secondary",
          "relevance_note": "Section 1368 \u2014 distributions",
          "source_code": "IRC_1368",
          "title": "IRC \u00a71368 \u2014 Distributions",
          "citation": "26 U.S.C. \u00a71368",
          "source_type": "code_section",
          "source_rank": "controlling"
        }
      ]
    },
    {
      "rule_id": "R003",
      "title": "Nondeductible expenses reduce next (Lines 7-8)",
      "description": "",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "stock_after_nonded = max(0, stock_after_distributions - nondeductible_expenses)",
      "inputs": [
        "stock_after_distributions",
        "nondeductible_expenses"
      ],
      "outputs": [
        "stock_after_nondeductible"
      ],
      "precedence": 3,
      "exceptions": "",
      "notes": "",
      "sort_order": 3,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Nondeductible expenses reduce next",
          "source_code": "IRS_2025_7203_INSTR_FULL",
          "title": "Instructions for Form 7203 (2025) \u2014 S Corporation Shareholder Stock and Debt Basis Limitation (fetched 2026-03-18)",
          "citation": "Instructions for Form 7203 (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R004",
      "title": "Losses reduce last \u2014 stock then debt (Part III)",
      "description": "Losses first reduce stock basis to zero, then debt basis. Excess is suspended and carried forward indefinitely with character retained.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "allowed_from_stock = min(losses_deductions, stock_after_nondeductible); allowed_from_debt = min(remaining, debt_basis); suspended = total - allowed",
      "inputs": [
        "losses_deductions",
        "stock_after_nondeductible",
        "debt_basis_boy"
      ],
      "outputs": [
        "stock_basis_eoy",
        "debt_basis_eoy",
        "suspended_losses"
      ],
      "precedence": 4,
      "exceptions": "",
      "notes": "",
      "sort_order": 4,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Losses reduce last \u2014 stock then debt",
          "source_code": "IRS_2025_7203_INSTR_FULL",
          "title": "Instructions for Form 7203 (2025) \u2014 S Corporation Shareholder Stock and Debt Basis Limitation (fetched 2026-03-18)",
          "citation": "Instructions for Form 7203 (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        },
        {
          "support_level": "secondary",
          "relevance_note": "Section 1366(d) \u2014 loss limitation",
          "source_code": "IRC_1366",
          "title": "IRC \u00a71366 \u2014 Pass-Through of Items to Shareholders",
          "citation": "26 U.S.C. \u00a71366",
          "source_type": "code_section",
          "source_rank": "controlling"
        }
      ]
    },
    {
      "rule_id": "R005",
      "title": "Stock basis floor at zero",
      "description": "Stock basis cannot go below zero. If computed negative, there is a calculation error.",
      "rule_type": "validation",
      "conditions": {},
      "formula": "stock_basis_eoy >= 0",
      "inputs": [
        "stock_basis_eoy"
      ],
      "outputs": [],
      "precedence": 0,
      "exceptions": "",
      "notes": "",
      "sort_order": 5,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Stock basis cannot be negative",
          "source_code": "IRS_2025_7203_INSTR_FULL",
          "title": "Instructions for Form 7203 (2025) \u2014 S Corporation Shareholder Stock and Debt Basis Limitation (fetched 2026-03-18)",
          "citation": "Instructions for Form 7203 (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R006",
      "title": "Debt basis restoration",
      "description": "Net income increases restore previously reduced debt basis, up to original loan face value.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "debt_restoration = min(net_income_increase, prior_debt_reduction)",
      "inputs": [
        "income_items",
        "debt_basis_boy"
      ],
      "outputs": [
        "debt_basis_restoration"
      ],
      "precedence": 5,
      "exceptions": "",
      "notes": "",
      "sort_order": 6,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Debt basis restoration via net income",
          "source_code": "IRS_2025_7203_INSTR_FULL",
          "title": "Instructions for Form 7203 (2025) \u2014 S Corporation Shareholder Stock and Debt Basis Limitation (fetched 2026-03-18)",
          "citation": "Instructions for Form 7203 (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R007",
      "title": "Distribution excess = capital gain",
      "description": "Distributions exceeding stock basis are treated as capital gain per section 1368. Report on Schedule D/Form 8949.",
      "rule_type": "conditional",
      "conditions": {},
      "formula": "if distributions > stock_basis_before_decreases then excess = capital_gain",
      "inputs": [
        "distributions",
        "stock_basis_before_decreases"
      ],
      "outputs": [
        "distribution_capital_gain"
      ],
      "precedence": 2,
      "exceptions": "",
      "notes": "",
      "sort_order": 7,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Section 1368 \u2014 excess distributions = capital gain",
          "source_code": "IRC_1368",
          "title": "IRC \u00a71368 \u2014 Distributions",
          "citation": "26 U.S.C. \u00a71368",
          "source_type": "code_section",
          "source_rank": "controlling"
        }
      ]
    }
