  "rules": [
    {
      "rule_id": "R001",
      "title": "\u00a7179 limitation",
      "description": "\u00a7179 deduction = lesser of: (a) elected cost, (b) $2,500,000 minus dollar-for-dollar reduction for total placed in service exceeding $4,000,000, (c) taxable income from active business. GA limit is $1,050,000/$2,620,000.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "min(elected_cost, max(0, 2500000 - max(0, total_placed_in_service - 4000000)), taxable_income)",
      "inputs": [
        "section_179_elected_cost",
        "total_section_179_placed_in_service",
        "taxable_income_limitation"
      ],
      "outputs": [
        "allowed_179_deduction"
      ],
      "precedence": 1,
      "exceptions": "",
      "notes": "",
      "sort_order": 1,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "\u00a7179(b) \u2014 limitation and phaseout computation",
          "source_code": "IRC_179",
          "title": "IRC \u00a7179 \u2014 Election to Expense Certain Depreciable Business Assets",
          "citation": "26 U.S.C. \u00a7179",
          "source_type": "code_section",
          "source_rank": "controlling"
        },
        {
          "support_level": "secondary",
          "relevance_note": "Part I instructions \u2014 \u00a7179 election and limits",
          "source_code": "IRS_2025_4562_INSTR",
          "title": "Instructions for Form 4562 \u2014 Depreciation and Amortization",
          "citation": "Form 4562 Instructions (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R002",
      "title": "OBBBA bonus depreciation",
      "description": "100% for assets acquired AND placed in service after 1/19/2025 (permanent under OBBBA). 40% for assets acquired before 1/20/2025 (binding contract rule). Bonus is on remaining basis after \u00a7179.",
      "rule_type": "calculation",
      "conditions": {
        "when": "bonus_percentage > 0"
      },
      "formula": "bonus_eligible_basis * bonus_percentage",
      "inputs": [
        "bonus_eligible_basis",
        "bonus_percentage",
        "acquisition_date"
      ],
      "outputs": [
        "bonus_depreciation_amount"
      ],
      "precedence": 5,
      "exceptions": "",
      "notes": "NEEDS REVIEW \u2014 verify binding contract date rules for 40% rate.",
      "sort_order": 2,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "\u00a7168(k) \u2014 bonus depreciation as amended by OBBBA",
          "source_code": "IRC_168",
          "title": "IRC \u00a7168 \u2014 Accelerated Cost Recovery System (MACRS)",
          "citation": "26 U.S.C. \u00a7168",
          "source_type": "code_section",
          "source_rank": "controlling"
        },
        {
          "support_level": "secondary",
          "relevance_note": "Part II instructions \u2014 special depreciation allowance",
          "source_code": "IRS_2025_4562_INSTR",
          "title": "Instructions for Form 4562 \u2014 Depreciation and Amortization",
          "citation": "Form 4562 Instructions (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R003",
      "title": "MACRS depreciation calculation",
      "description": "Apply IRS Pub 946 tables based on recovery period, method, and convention. Depreciable basis = original cost minus \u00a7179 minus bonus.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "depreciable_basis * pub_946_percentage(recovery_period, method, convention, year)",
      "inputs": [
        "depreciable_basis",
        "recovery_period",
        "depreciation_method",
        "convention"
      ],
      "outputs": [
        "current_year_depreciation"
      ],
      "precedence": 10,
      "exceptions": "",
      "notes": "",
      "sort_order": 3,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "\u00a7168(a)-(b) \u2014 MACRS general rules",
          "source_code": "IRC_168",
          "title": "IRC \u00a7168 \u2014 Accelerated Cost Recovery System (MACRS)",
          "citation": "26 U.S.C. \u00a7168",
          "source_type": "code_section",
          "source_rank": "controlling"
        },
        {
          "support_level": "primary",
          "relevance_note": "Pub 946 \u2014 MACRS percentage tables",
          "source_code": "IRS_PUB_946",
          "title": "IRS Publication 946 \u2014 How to Depreciate Property",
          "citation": "Publication 946 (2025)",
          "source_type": "official_publication",
          "source_rank": "primary_official"
        },
        {
          "support_level": "secondary",
          "relevance_note": "Part III instructions \u2014 MACRS depreciation",
          "source_code": "IRS_2025_4562_INSTR",
          "title": "Instructions for Form 4562 \u2014 Depreciation and Amortization",
          "citation": "Form 4562 Instructions (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R004",
      "title": "\u00a7179 flows to Schedule K (not Page 1)",
      "description": "For S-Corps and partnerships, \u00a7179 is a separately stated item. It does NOT reduce ordinary income. It flows to Schedule K Line 11 (1120-S) or K Line 12 (1065).",
      "rule_type": "routing",
      "conditions": {
        "when": "entity_type in [\"1120S\", \"1065\"]"
      },
      "formula": "allowed_179_deduction \u2192 Schedule K Line 11 (1120S) or K Line 12 (1065)",
      "inputs": [
        "allowed_179_deduction",
        "entity_type"
      ],
      "outputs": [
        "schedule_k_179"
      ],
      "precedence": 15,
      "exceptions": "",
      "notes": "",
      "sort_order": 4,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "\u00a7179(d)(4) \u2014 separately stated for passthrough entities",
          "source_code": "IRC_179",
          "title": "IRC \u00a7179 \u2014 Election to Expense Certain Depreciable Business Assets",
          "citation": "26 U.S.C. \u00a7179",
          "source_type": "code_section",
          "source_rank": "controlling"
        },
        {
          "support_level": "secondary",
          "relevance_note": "Schedule K Line 11 \u2014 \u00a7179 deduction",
          "source_code": "IRS_2025_1120S_INSTR",
          "title": "Instructions for Form 1120-S \u2014 U.S. Income Tax Return for an S Corporation",
          "citation": "Form 1120-S Instructions (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R005",
      "title": "Depreciation flows to Page 1",
      "description": "MACRS + bonus depreciation (excluding \u00a7179) flows to Page 1 Line 14 (1120-S). Unlike \u00a7179, regular depreciation and bonus are NOT separately stated.",
      "rule_type": "routing",
      "conditions": {},
      "formula": "current_year_depreciation + bonus_depreciation_amount \u2192 Page 1 deduction line",
      "inputs": [
        "current_year_depreciation",
        "bonus_depreciation_amount"
      ],
      "outputs": [
        "page_1_depreciation"
      ],
      "precedence": 15,
      "exceptions": "",
      "notes": "",
      "sort_order": 5,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Page 1 Line 14 \u2014 depreciation (non-\u00a7179)",
          "source_code": "IRS_2025_1120S_INSTR",
          "title": "Instructions for Form 1120-S \u2014 U.S. Income Tax Return for an S Corporation",
          "citation": "Form 1120-S Instructions (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        },
        {
          "support_level": "secondary",
          "relevance_note": "Line 22 total \u2192 entity return",
          "source_code": "IRS_2025_4562_INSTR",
          "title": "Instructions for Form 4562 \u2014 Depreciation and Amortization",
          "citation": "Form 4562 Instructions (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R006",
      "title": "\u00a7197 amortization",
      "description": "\u00a7197 intangibles amortized over 180 months (15 years) straight-line. Includes goodwill, going concern value, covenants not to compete, franchises, trademarks.",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "amortizable_amount / 180 * months_in_service_this_year",
      "inputs": [
        "amortizable_amount",
        "amortization_period_months",
        "amortization_start_date"
      ],
      "outputs": [
        "current_year_amortization"
      ],
      "precedence": 10,
      "exceptions": "",
      "notes": "",
      "sort_order": 6,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "\u00a7197 \u2014 180-month amortization of intangibles",
          "source_code": "IRC_197",
          "title": "IRC \u00a7197 \u2014 Amortization of Goodwill and Certain Other Intangibles",
          "citation": "26 U.S.C. \u00a7197",
          "source_type": "code_section",
          "source_rank": "controlling"
        },
        {
          "support_level": "secondary",
          "relevance_note": "Part V instructions \u2014 amortization",
          "source_code": "IRS_2025_4562_INSTR",
          "title": "Instructions for Form 4562 \u2014 Depreciation and Amortization",
          "citation": "Form 4562 Instructions (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
