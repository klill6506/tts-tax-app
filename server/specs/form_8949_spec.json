  "rules": [
    {
      "rule_id": "R001",
      "title": "Determine reporting category",
      "description": "Category A/B/C (short-term) or D/E/F (long-term) based on holding period and 1099-B basis reporting.",
      "rule_type": "classification",
      "conditions": {},
      "formula": "category based on (1) ST vs LT holding period, (2) whether basis reported on 1099-B",
      "inputs": [
        "date_acquired",
        "date_sold",
        "basis_reported_to_irs"
      ],
      "outputs": [
        "reporting_category"
      ],
      "precedence": 1,
      "exceptions": "",
      "notes": "",
      "sort_order": 1,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Form 8949 instructions \u2014 reporting category determination",
          "source_code": "IRS_2025_8949_INSTR",
          "title": "Instructions for Form 8949 \u2014 Sales and Other Dispositions of Capital Assets",
          "citation": "Form 8949 Instructions (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        },
        {
          "support_level": "secondary",
          "relevance_note": "\u00a71222 \u2014 ST vs LT holding period definitions",
          "source_code": "IRC_1222",
          "title": "IRC \u00a71222 \u2014 Other Terms Relating to Capital Gains and Losses",
          "citation": "26 U.S.C. \u00a71222",
          "source_type": "code_section",
          "source_rank": "controlling"
        }
      ]
    },
    {
      "rule_id": "R002",
      "title": "Calculate gain or loss per transaction",
      "description": "Gain/loss = proceeds minus cost basis plus/minus adjustments (adjustments can be positive or negative).",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "proceeds - cost_basis + adjustment_amount",
      "inputs": [
        "proceeds",
        "cost_basis",
        "adjustment_amount"
      ],
      "outputs": [
        "gain_or_loss"
      ],
      "precedence": 5,
      "exceptions": "",
      "notes": "",
      "sort_order": 2,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Column (h) instructions \u2014 gain/loss computation",
          "source_code": "IRS_2025_8949_INSTR",
          "title": "Instructions for Form 8949 \u2014 Sales and Other Dispositions of Capital Assets",
          "citation": "Form 8949 Instructions (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R003",
      "title": "Adjustment codes",
      "description": "Code B = basis incorrect on 1099-B (correction amount). Code T = wash sale (loss disallowed under \u00a71091). Code W = collectibles (28% rate). Code O = other.",
      "rule_type": "classification",
      "conditions": {},
      "formula": "code depends on type of adjustment",
      "inputs": [
        "adjustment_code"
      ],
      "outputs": [
        "adjustment_treatment"
      ],
      "precedence": 1,
      "exceptions": "",
      "notes": "",
      "sort_order": 3,
