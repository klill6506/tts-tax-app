  "diagnostics": [
    {
      "diagnostic_id": "D001",
      "title": "Proceeds differ from 1099-B",
      "severity": "warning",
      "condition": "basis_reported_to_irs == true AND adjustment needed but no code entered",
      "message": "Proceeds or basis on 1099-B may differ from actual amounts. If basis is incorrect, use Code B with the correction in column (g).",
      "notes": ""
    },
    {
      "diagnostic_id": "D002",
      "title": "Wash sale not coded",
      "severity": "warning",
      "condition": "same security sold at loss within 30-day window",
      "message": "A wash sale may apply. If the same or substantially identical security was purchased within 30 days before or after this sale at a loss, use Code T and enter the disallowed loss in column (g).",
      "notes": ""
    },
    {
      "diagnostic_id": "D003",
      "title": "Missing date acquired",
      "severity": "error",
      "condition": "date_acquired is null",
      "message": "Date acquired is required to determine holding period (short-term vs long-term) and correct reporting category.",
      "notes": ""
    }
  ],
  "tests": [
    {
      "scenario_name": "Simple stock sale \u2014 basis correct, no adjustments",
      "scenario_type": "normal",
      "inputs": {
        "proceeds": 15000,
        "date_sold": "2025-06-01",
        "cost_basis": 10000,
        "description": "100 shares XYZ Corp",
        "date_acquired": "2023-01-15",
        "adjustment_code": null,
        "adjustment_amount": 0,
        "basis_reported_to_irs": true
      },
      "expected_outputs": {
        "gain_or_loss": 5000,
        "reporting_category": "D"
      },
      "notes": "Held >1yr = LT. Basis reported = category D. Gain = 15K-10K = 5K.",
      "sort_order": 1
    },
    {
      "scenario_name": "Basis adjustment \u2014 1099-B shows wrong basis",
      "scenario_type": "normal",
      "inputs": {
        "proceeds": 8000,
        "date_sold": "2025-02-15",
        "cost_basis": 6000,
        "description": "200 shares ABC Inc",
        "date_acquired": "2024-03-01",
        "adjustment_code": "B",
        "adjustment_amount": -500,
        "basis_reported_to_irs": true
      },
      "expected_outputs": {
        "gain_or_loss": 1500,
        "reporting_category": "A"
      },
      "notes": "Held \u22641yr = ST. Code B adjusts basis. Gain = 8000-6000+(-500) = 1500.",
      "sort_order": 2
    },
    {
      "scenario_name": "Wash sale \u2014 loss disallowed",
      "scenario_type": "edge",
      "inputs": {
        "proceeds": 4000,
        "date_sold": "2025-04-05",
        "cost_basis": 5000,
        "description": "50 shares DEF Ltd",
        "date_acquired": "2025-01-10",
        "adjustment_code": "T",
        "adjustment_amount": 1000,
        "basis_reported_to_irs": true
      },
      "expected_outputs": {
        "gain_or_loss": 0,
        "reporting_category": "A"
      },
      "notes": "Loss of $1K disallowed as wash sale. Code T, adjustment +1000. Net = 4000-5000+1000 = 0.",
      "sort_order": 3
    }
  ]
}