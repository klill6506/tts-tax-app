  "diagnostics": [
    {
      "diagnostic_id": "D001",
      "title": "AAA distributions exceed balance",
      "severity": "warning",
      "condition": "aaa_distributions > max(0, aaa_combined)",
      "message": "Distributions exceed AAA balance. Excess treated as return of basis (section 1368). AAA cannot be reduced below zero by distributions.",
      "notes": ""
    },
    {
      "diagnostic_id": "D002",
      "title": "AAA negative from losses",
      "severity": "info",
      "condition": "aaa_ending < 0",
      "message": "AAA ending balance is negative due to losses exceeding income. This is permitted \u2014 only distributions cannot make AAA negative, not losses.",
      "notes": ""
    }
  ],
  "tests": [
    {
      "scenario_name": "Basic M-2 \u2014 income, additions, distributions within AAA",
      "scenario_type": "normal",
      "inputs": {
        "aaa_loss": 0,
        "aaa_beginning": 50000,
        "aaa_distributions": 40000,
        "aaa_ordinary_income": 95000,
        "aaa_other_additions": 0,
        "aaa_other_reductions": 3000
      },
      "expected_outputs": {
        "aaa_ending": 102000,
        "aaa_combined": 142000
      },
      "notes": "Simple case: 50K + 95K - 3K = 142K combined - 40K distributions = 102K ending.",
      "sort_order": 1
    },
    {
      "scenario_name": "Distributions exceeding AAA \u2014 capped at zero",
      "scenario_type": "edge",
      "inputs": {
        "aaa_loss": 0,
        "aaa_beginning": 20000,
        "aaa_distributions": 80000,
        "aaa_ordinary_income": 30000,
        "aaa_other_additions": 0,
        "aaa_other_reductions": 0
      },
      "expected_outputs": {
        "aaa_ending": 0,
        "aaa_combined": 50000
      },
      "notes": "Distributions ($80K) exceed AAA ($50K). AAA goes to zero, not negative. Excess $30K treated as return of basis/capital gain per section 1368.",
      "sort_order": 2
    },
    {
      "scenario_name": "Loss making AAA negative",
      "scenario_type": "edge",
      "inputs": {
        "aaa_loss": 50000,
        "aaa_beginning": 20000,
        "aaa_distributions": 0,
        "aaa_ordinary_income": 0,
        "aaa_other_additions": 0,
        "aaa_other_reductions": 0
      },
      "expected_outputs": {
        "aaa_ending": -30000,
        "aaa_combined": -30000
      },
      "notes": "Losses CAN make AAA negative (unlike distributions). AAA = 20K - 50K loss = -30K.",
      "sort_order": 3
    }
  ]
