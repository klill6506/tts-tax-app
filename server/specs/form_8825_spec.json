    {
      "rule_id": "R003",
      "title": "Total net rental -> K Line 2",
      "description": "Sum of all property net rents flows to Schedule K Line 2.",
      "rule_type": "routing",
      "conditions": {},
      "formula": "K2 = sum(all net_rent)",
