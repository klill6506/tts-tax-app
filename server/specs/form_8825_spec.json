  "rules": [
    {
      "rule_id": "R001",
      "title": "Total expenses per property (Line 16)",
      "description": "",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "sum(Lines 3-15)",
      "inputs": [
        "advertising",
        "auto_travel",
        "cleaning",
        "commissions",
        "insurance",
        "legal_professional",
        "mortgage_interest",
        "other_interest",
        "repairs",
        "taxes",
        "utilities",
        "depreciation",
        "other_expenses"
      ],
      "outputs": [
        "total_expenses"
      ],
      "precedence": 1,
      "exceptions": "",
      "notes": "",
      "sort_order": 1,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Per-property expense total",
          "source_code": "IRS_2025_8825_INSTR_FULL",
          "title": "Instructions for Form 8825 (2025) \u2014 Rental Real Estate Income and Expenses (fetched 2026-03-18)",
          "citation": "Instructions for Form 8825 (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R002",
      "title": "Net rent per property (Line 17)",
      "description": "",
      "rule_type": "calculation",
      "conditions": {},
      "formula": "gross_rents - total_expenses",
      "inputs": [
        "gross_rents",
        "total_expenses"
      ],
      "outputs": [
        "net_rent"
      ],
      "precedence": 2,
      "exceptions": "",
      "notes": "",
      "sort_order": 2,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "Net rent = gross - expenses",
          "source_code": "IRS_2025_8825_INSTR_FULL",
