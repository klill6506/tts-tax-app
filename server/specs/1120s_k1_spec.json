    {
      "rule_id": "R018",
      "title": "Basis limitation check",
      "description": "Shareholder cannot deduct losses exceeding stock + debt basis. Losses limited in order: (1) ordinary loss, (2) separately stated losses, (3) capital losses. Form 7203 required.",
      "rule_type": "validation",
      "conditions": {},
      "formula": "total_losses <= stock_basis_boy + debt_basis",
      "inputs": [
        "box_1_ordinary_income",
        "stock_basis_boy",
        "debt_basis"
      ],
      "outputs": [
        "deductible_loss",
        "suspended_loss"
      ],
      "precedence": 10,
      "exceptions": "",
      "notes": "NEEDS REVIEW \u2014 ordering of loss limitation categories across all box types.",
      "sort_order": 18,
      "authorities": [
        {
          "support_level": "primary",
          "relevance_note": "\u00a71366(d) \u2014 loss limited to stock + debt basis",
          "source_code": "IRC_1366",
          "title": "IRC \u00a71366 \u2014 Pass-Through of Items to Shareholders",
          "citation": "26 U.S.C. \u00a71366",
          "source_type": "code_section",
          "source_rank": "controlling"
        },
        {
          "support_level": "secondary",
          "relevance_note": "Form 7203 \u2014 basis computation and loss limitation",
          "source_code": "IRS_2025_7203_INSTR",
          "title": "Instructions for Form 7203 \u2014 S Corporation Shareholder Stock and Debt Basis Limitations",
          "citation": "Form 7203 Instructions (2025)",
          "source_type": "official_instruction",
          "source_rank": "primary_official"
        }
      ]
    },
    {
      "rule_id": "R019",
      "title": "At-risk limitation (post-basis)",
      "description": "After basis limitation, remaining deductible amounts are further limited to at-risk amount under \u00a7465. Form 6198.",
      "rule_type": "validation",
      "conditions": {},
      "formula": "deductible_after_basis <= at_risk_amount",
      "inputs": [
        "deductible_loss",
        "at_risk_amount"
