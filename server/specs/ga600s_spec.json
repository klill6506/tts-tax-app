  "tests": [
    {
      "scenario_name": "Single-state GA S-Corp \u2014 no bonus difference",
      "scenario_type": "normal",
      "inputs": {
        "ga_subtraction_depr": 0,
        "ga_apportionment_pct": 100,
        "federal_taxable_income": 95000,
        "ga_addition_bonus_depr": 0
      },
      "expected_outputs": {
        "ga_taxable_income": 95000
      },
      "notes": "No bonus depreciation, so GA income = federal income.",
      "sort_order": 1
    },
    {
      "scenario_name": "S-Corp with bonus depreciation \u2014 GA addback",
      "scenario_type": "normal",
      "inputs": {
        "ga_subtraction_depr": 14286,
        "ga_apportionment_pct": 100,
        "federal_taxable_income": 50000,
        "ga_addition_bonus_depr": 100000
      },
      "expected_outputs": {
        "ga_taxable_income": 135714
      },
      "notes": "Federal took $100K bonus. GA adds back $100K, subtracts $14,286 GA depreciation (7yr SL year 1). GA income much higher.",
      "sort_order": 2
    },
    {
      "scenario_name": "PTET election",
      "scenario_type": "normal",
      "inputs": {
        "ptet_rate": 5.49,
        "ptet_elected": true,
        "ptet_taxable_income": 200000
      },
      "expected_outputs": {
        "ptet_tax": 10980
      },
      "notes": "$200K * 5.49% = $10,980 PTET.",
      "sort_order": 3
    },
    {
      "scenario_name": "Multi-state \u2014 60% GA apportionment",
      "scenario_type": "edge",
      "inputs": {
        "ga_apportionment_pct": 60,
        "federal_taxable_income": 200000
      },
      "expected_outputs": {
        "ga_apportioned_income": 120000
      },
      "notes": "60% of $200K = $120K subject to GA tax.",
      "sort_order": 4
    }
  ]
