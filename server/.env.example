DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-production

# Supabase Postgres (shared with sherpa-1099 production app).
# Get these from the Supabase dashboard: Settings -> Database -> Connection info.
# Use the pooler connection string; the host format is aws-<region>.pooler.supabase.com.
DB_NAME=postgres
DB_USER=postgres.<your-supabase-project-ref>
DB_PASSWORD=<get-from-supabase-dashboard>
DB_HOST=aws-1-us-east-1.pooler.supabase.com
DB_PORT=5432

# Gemini API (IRS-grounded help)
GEMINI_API_KEY=
