# Reference PDFs (large binaries, not tracked)
Official IRS Forms/
Official IRS Instructions/

# IRS instruction PDFs (downloaded via scripts/update_irs_forms.py, too large for git)
resources/irs_forms/2025/i*.pdf

# Electron client local env
client/.env.local

# Data files — never commit client-bearing artifacts
# All client data lives in Supabase; local working files belong in D:\tax-test-data\
# NOTE: *.csv and *.xlsx are unscoped (ignored anywhere in tree). If a future
# test fixture needs to be tracked, add a ! exception (e.g. !server/tests/fixtures/sample.csv)
# or use `git add -f`.
*.csv
*.xlsx
*.xls
/*.pdf
/Lacerte Export/
/tax-test-data/
/lacerte_pdfs/

# Shell artifacts
NUL

# Dev-artifact PDFs in subdirectories
server/*.pdf
*.pdf.bak

# Ad-hoc dev scripts (use server/tests/ for real tests, server/scripts/ only for committed utilities)
server/scripts/test_*.py
server/scripts/debug_*.py
server/scripts/check_*.py
server/scripts/inspect_*.py
server/scripts/verify_*.py
server/scripts/extract_*.py
server/scripts/fix_*.py
server/scripts/kill_test_db*.py

# Reference design artifacts (not source-of-truth)
/Gemini Stitch/
/Line by Line Adjustments/

# IDE local state
.claude/settings.local.json
